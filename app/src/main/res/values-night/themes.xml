<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- AppCompat parent required for AppCompatActivity + setApplicationLocales -->
    <style name="Theme.PdfExplorer" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme for Android 12+ Splash Screen API (night) -->
    <style name="Theme.PdfExplorer.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bgColor</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/img_splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.PdfExplorer</item>
    </style>

</resources>
